# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================
# 🔒 SENSITIVE / SECRET FILES
# ============================

# Environment variables (API keys, DB URLs, secrets)
.env
.env.*
!.env.example

# Google OAuth client secret JSON
client_secret_*.json

# SQLite database files (local dev data)
*.db
prisma/dev.db

# ============================
# 🛠️ ADMIN / DEBUG SCRIPTS
# ============================

# One-off admin scripts with hardcoded emails/passwords
add_user.js
check-credits.js
give_credits.js
verify-resume-save.mjs

# Backup files
*.bak

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
