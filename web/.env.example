# ============================
# Firebase Configuration
# ============================
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================
# Database
# ============================
DATABASE_URL=file:./dev.db

# ============================
# NextAuth.js
# ============================
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ============================
# Google OAuth
# ============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================
# Gemini AI
# ============================
GEMINI_API_KEY=your_gemini_api_key

# ============================
# Razorpay (Payment Gateway)
# ============================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================
# Dodo Payments
# ============================
DODO_API_KEY=your_dodo_api_key
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_key
DODO_PAYMENTS_ENVIRONMENT=live

# Optional override (defaults already mapped in code)
DODO_PRODUCT_ID_STANDARD_INR=pdt_0NbPnI0p4tBHBoUH9QXAp
DODO_PRODUCT_ID_STANDARD_USD=pdt_0NbPm2bcYNCLAy3r1YGHv
DODO_PRODUCT_ID_PRO_INR=pdt_0NbPnQl3VYLwC8jHaU4wo
DODO_PRODUCT_ID_PRO_USD=pdt_0NbPmFNx2kw1gRVX3Kdhe

# ============================
# Email OTP Verification (Resend)
# ============================
# Get your free API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here
