# ============================
# Root-level .gitignore
# ============================

# OS files
.DS_Store
Thumbs.db

# ============================
# Web (Next.js) - web/
# ============================
web/node_modules/
web/.next/
web/out/
web/build/
web/.pnp
web/.pnp.*
web/.yarn/*
!web/.yarn/patches
!web/.yarn/plugins
!web/.yarn/releases
!web/.yarn/versions
web/coverage/
web/.vercel
web/*.tsbuildinfo
web/next-env.d.ts
web/app/generated/prisma

# ============================
# 🔒 SENSITIVE / SECRET FILES
# ============================

# Environment variables (contains API keys, DB URLs, secrets)
.env
.env.*
!.env.example

# Google OAuth client secret JSON
web/client_secret_*.json

# SQLite database files (local dev data only)
*.db

# ============================
# 🛠️ ADMIN / DEBUG SCRIPTS
# ============================

# One-off admin scripts with hardcoded emails/passwords
web/add_user.js
web/check-credits.js
web/give_credits.js
web/verify-resume-save.mjs

# Backup files
*.bak

# ============================
# Python Service - python-service/
# ============================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
python-service/venv/
python-service/.venv/
python-service/env/

# Temp generated files (build artifacts)
python-service/temp_gen/

# ============================
# Misc
# ============================
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
